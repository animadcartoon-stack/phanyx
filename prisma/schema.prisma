  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  instituicaoId Int

  instituicao            Instituicao            @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  professores            Professor[]
  turmas                 Turma[]
  alunos                 Aluno[]
  cursosPolos            CursoPolo[]
  matriculas             Matricula[]
  cobrancas              Cobranca[]
  lancamentosFinanceiros LancamentoFinanceiro[]

  @@unique([instituicaoId, nome])
  @@unique([instituicaoId, codigo])
  @@index([instituicaoId])
  @@index([cnpj])
}

model CursoPolo {
  id            Int      @id @default(autoincrement())
  cursoId       Int
  poloId        Int
  instituicaoId Int
  createdAt     DateTime @default(now())

  curso       Curso       @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  polo        Polo        @relation(fields: [poloId], references: [id], onDelete: Cascade)
  instituicao Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@unique([cursoId, poloId])
  @@index([instituicaoId])
  @@index([cursoId])
  @@index([poloId])
}

