generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Instituicao {
  id                         Int                             @id @default(autoincrement())
  nome                       String
  ativo                      Boolean                         @default(true)
  createdAt                  DateTime                        @default(now())
  dominio                    String?                         @unique
  slug                       String                          @unique
  updatedAt                  DateTime
  plano                      String                          @default("ESSENCIAL")
  alternativas               Alternativa[]
  alunos                     Aluno[]
  atestadosMedicos           AtestadoMedico[]
  atividades                 Atividade[]
  anexosAtividade            AtividadeAnexo[]
  aulas                      Aula[]
  caixas                     Caixa[]
  certificados               Certificado[]
  cobrancas                  Cobranca[]
  configuracaoInstituicao    ConfiguracaoInstituicao?
  contratos                  Contrato[]
  cursos                     Curso[]
  cursoSemestres             CursoSemestre[]
  cursoSemestreDisciplinas   CursoSemestreDisciplina[]
  Departamento               Departamento[]
  disciplinas                Disciplina[]
  documentosAlunos           DocumentoAluno[]
  documentosGerados          DocumentoGerado[]
  documentoTemplates         DocumentoTemplate[]
  entregas                   EntregaAtividade[]
  Funcionario                Funcionario[]
  itensMatricula             ItemMatricula[]
  lancamentosFinanceiros     LancamentoFinanceiro[]
  materiaisAula              MaterialAula[]
  matriculas                 Matricula[]
  modulos                    Modulo[]
  movimentosCaixa            MovimentoCaixa[]
  notas                      Nota[]
  pagamentos                 Pagamento[]
  presencasAula              PresencaAula[]
  professores                Professor[]
  progressoAulas             ProgressoAula[]
  provas                     Prova[]
  questoes                   Questao[]
  respostas                  RespostaProva[]
  resultadosFinais           ResultadoFinal[]
  tentativas                 TentativaProva[]
  turmas                     Turma[]
  usuarios                   User[]
  polos                      Polo[]
  adesoes                    AdesaoInstituicao[]
  TurmaDisciplina            TurmaDisciplina[]
  certificadoCampos          CertificadoCampo[]
  periodosMatricula          PeriodoMatricula[]
  disciplinaPreRequisitos    DisciplinaPreRequisito[]
  cursosDisciplinasExtras    CursoDisciplinaExtraPermitida[]
  certificadoTemplateUrl     String?
  certificadoPreviewUrl      String?
  certificadoTextoPadrao     String?
  certificadoAssinaturaUrl   String?
  certificadoCoordenadorNome String?
  certificadoCidade          String?
  cursosPolos                CursoPolo[]
}

model User {
  id                 Int          @id @default(autoincrement())
  nome               String
  email              String       @unique
  senha              String
  createdAt          DateTime     @default(now())
  instituicaoId      Int
  ativo              Boolean      @default(true)
  updatedAt          DateTime     @updatedAt
  role               Role
  ultimoLoginAt      DateTime?
  aluno              Aluno?
  funcionario        Funcionario?
  professor          Professor?
  resetToken         String?
  resetTokenExpira   DateTime?
  precisaTrocarSenha Boolean      @default(false)
  isMasterAdmin      Boolean      @default(false)
  instituicao        Instituicao  @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@index([instituicaoId])
  @@index([role])
}

model Aluno {
  id                           Int                    @id @default(autoincrement())
  nome                         String
  createdAt                    DateTime               @default(now())
  instituicaoId                Int
  userId                       Int                    @unique
  ativo                        Boolean                @default(true)
  matricula                    String?
  updatedAt                    DateTime               @updatedAt
  bairro                       String?
  cep                          String?
  cidade                       String?
  complemento                  String?
  cpf                          String?
  dataNascimento               DateTime?
  documentoUrl                 String?
  endereco                     String?
  estado                       String?
  numero                       String?
  rg                           String?
  slug                         String?
  telefone                     String?
  cpfResponsavel               String?
  emailResponsavel             String?
  nomeResponsavel              String?
  parentescoResponsavel        String?
  telefoneResponsavel          String?
  statusAluno                  StatusAluno            @default(ATIVO)
  descricaoNecessidadeEspecial String?
  observacoesAcessibilidade    String?
  possuiNecessidadeEspecial    Boolean                @default(false)
  genero                       String?
  nomeSocial                   String?
  poloId                       Int?
  instituicao                  Instituicao            @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  polo                         Polo?                  @relation(fields: [poloId], references: [id])
  user                         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  atestadosMedicos             AtestadoMedico[]
  certificados                 Certificado[]
  cobrancas                    Cobranca[]
  contratos                    Contrato[]
  documentos                   DocumentoAluno[]
  DocumentoGerado              DocumentoGerado[]
  entregas                     EntregaAtividade[]
  lancamentosFinanceiros       LancamentoFinanceiro[]
  matriculas                   Matricula[]
  movimentosCaixa              MovimentoCaixa[]
  notas                        Nota[]
  pagamentos                   Pagamento[]
  presencasAula                PresencaAula[]
  progresso                    ProgressoAula[]
  respostas                    RespostaProva[]
  resultadosFinais             ResultadoFinal[]
  tentativas                   TentativaProva[]

  @@unique([instituicaoId, matricula])
  @@unique([instituicaoId, slug])
  @@index([instituicaoId])
  @@index([nome])
  @@index([cpf])
  @@index([statusAluno])
  @@index([poloId])
}

model Professor {
  id                Int         @id @default(autoincrement())
  nome              String
  createdAt         DateTime    @default(now())
  instituicaoId     Int
  userId            Int         @unique
  ativo             Boolean     @default(true)
  updatedAt         DateTime    @updatedAt
  codigoFuncionario String?
  cpf               String?
  dataNascimento    DateTime?
  documentoUrl      String?
  especialidade     String?
  formacao          String?
  fotoPerfil        String?
  miniBio           String?
  rg                String?
  slug              String?
  telefone          String?
  titulacao         String?
  instituicao       Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  turmas            Turma[]
  turmaDisciplinas  TurmaDisciplina[]
  disciplinasPadrao Disciplina[]
  poloId            Int?
  polo              Polo?       @relation(fields: [poloId], references: [id])

  @@unique([instituicaoId, slug])
  @@index([instituicaoId])
  @@index([nome])
  @@index([cpf])
  @@index([poloId])
}

model Curso {
  id                          Int                             @id @default(autoincrement())
  nome                        String
  descricao                   String?
  ativo                       Boolean                         @default(true)
  createdAt                   DateTime                        @default(now())
  instituicaoId               Int
  codigo                      String?
  updatedAt                   DateTime                        @updatedAt
  quantidadeParcelas          Int?
  valorMatricula              Float?
  valorMensalidade            Float?
  quantidadeSemestres         Int?
  cargaHorariaMaximaSemestre  Int?
  instituicao                 Instituicao                     @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  semestres                   CursoSemestre[]
  disciplinas                 Disciplina[]
  documentosGerados           DocumentoGerado[]
  matriculas                  Matricula[]
  turmas                      Turma[]
  periodosMatricula           PeriodoMatricula[]
  disciplinasExtrasPermitidas CursoDisciplinaExtraPermitida[]
  cursosPolos                 CursoPolo[]

  @@unique([instituicaoId, nome])
  @@unique([instituicaoId, codigo])
  @@index([instituicaoId])
}

model CursoSemestre {
  id            Int                       @id @default(autoincrement())
  numero        Int
  titulo        String?
  descricao     String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  instituicaoId Int
  cursoId       Int
  cargaMaxima   Int?
  curso         Curso                     @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  instituicao   Instituicao               @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  disciplinas   CursoSemestreDisciplina[]
  matriculas    Matricula[]

  @@unique([cursoId, numero])
  @@index([instituicaoId])
  @@index([cursoId])
}

model CursoSemestreDisciplina {
  id              Int           @id @default(autoincrement())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  instituicaoId   Int
  cursoSemestreId Int
  disciplinaId    Int
  cursoSemestre   CursoSemestre @relation(fields: [cursoSemestreId], references: [id], onDelete: Cascade)
  disciplina      Disciplina    @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  instituicao     Instituicao   @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@unique([cursoSemestreId, disciplinaId])
  @@index([instituicaoId])
  @@index([cursoSemestreId])
  @@index([disciplinaId])
}

model Pagamento {
  id             Int                  @id @default(autoincrement())
  valorPago      Float
  pagoEm         DateTime             @default(now())
  formaPagamento FormaPagamento?
  observacao     String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  instituicaoId  Int
  alunoId        Int
  lancamentoId   Int
  aluno          Aluno                @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  instituicao    Instituicao          @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  lancamento     LancamentoFinanceiro @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)

  @@index([instituicaoId])
  @@index([alunoId])
  @@index([lancamentoId])
}

model LancamentoFinanceiro {
  id              Int                        @id @default(autoincrement())
  tipo            TipoLancamentoFinanceiro
  descricao       String?
  valorOriginal   Float
  valorPago       Float?                     @default(0)
  vencimento      DateTime?
  pagoEm          DateTime?
  status          StatusLancamentoFinanceiro @default(PENDENTE)
  poloId          Int?
  polo            Polo?                      @relation(fields: [poloId], references: [id])
  observacao      String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  instituicaoId   Int
  alunoId         Int
  matriculaId     Int?
  descontoValor   Float?                     @default(0)
  jurosValor      Float?                     @default(0)
  multaValor      Float?                     @default(0)
  valorFinal      Float?                     @default(0)
  aluno           Aluno                      @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  instituicao     Instituicao                @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  matricula       Matricula?                 @relation(fields: [matriculaId], references: [id])
  movimentosCaixa MovimentoCaixa[]
  pagamentos      Pagamento[]

  @@index([instituicaoId])
  @@index([alunoId])
  @@index([matriculaId])
  @@index([status])
  @@index([tipo])
}

model DocumentoAluno {
  id            Int                @id @default(autoincrement())
  titulo        String
  tipo          TipoDocumentoAluno
  arquivoUrl    String?
  conteudo      String?
  criadoEm      DateTime           @default(now())
  alunoId       Int
  instituicaoId Int
  matriculaId   Int?
  aluno         Aluno              @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  instituicao   Instituicao        @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  matricula     Matricula?         @relation(fields: [matriculaId], references: [id])

  @@index([alunoId])
  @@index([instituicaoId])
}

model Disciplina {
  id                        Int                             @id @default(autoincrement())
  nome                      String
  cursoId                   Int?
  instituicaoId             Int
  descricao                 String?
  semestre                  Int?
  ativo                     Boolean                         @default(true)
  codigo                    String?
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt
  cargaHoraria              Int?
  certificados              Certificado[]
  semestresCurso            CursoSemestreDisciplina[]
  professorId               Int?
  professor                 Professor?                      @relation(fields: [professorId], references: [id])
  curso                     Curso?                          @relation(fields: [cursoId], references: [id])
  instituicao               Instituicao                     @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  resultadosFinais          ResultadoFinal[]
  itensMatricula            ItemMatricula[]
  prerequisitosDaDisciplina DisciplinaPreRequisito[]        @relation("DisciplinaPrincipal")
  liberaOutrasDisciplinas   DisciplinaPreRequisito[]        @relation("DisciplinaPreRequisito")
  permitidaComoExtraEm      CursoDisciplinaExtraPermitida[]
  turmaDisciplinas          TurmaDisciplina[]

  @@unique([instituicaoId, nome])
  @@unique([instituicaoId, codigo])
  @@index([instituicaoId])
  @@index([cursoId])
  @@index([professorId])
}

model Turma {
  id               Int               @id @default(autoincrement())
  nome             String
  semestre         String
  professorId      Int?
  instituicaoId    Int
  ativa            Boolean           @default(true)
  codigo           String?
  createdAt        DateTime          @default(now())
  periodoLetivo    String?
  updatedAt        DateTime          @updatedAt
  capacidadeMaxima Int?
  capacidadeMinima Int?
  cursoId          Int?
  statusTurma      StatusTurma       @default(AGUARDANDO)
  atividades       Atividade[]
  aulas            Aula[]
  itensMatricula   ItemMatricula[]
  modulos          Modulo[]
  notas            Nota[]
  provas           Prova[]
  resultadosFinais ResultadoFinal[]
  curso            Curso?            @relation(fields: [cursoId], references: [id])
  instituicao      Instituicao       @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  professor        Professor?        @relation(fields: [professorId], references: [id])
  disciplinas      TurmaDisciplina[]
  poloId           Int?
  polo             Polo?             @relation(fields: [poloId], references: [id])

  @@unique([instituicaoId, nome, semestre])
  @@index([instituicaoId])
  @@index([professorId])
  @@index([statusTurma])
  @@index([poloId])
}

model TurmaDisciplina {
  id            Int      @id @default(autoincrement())
  turmaId       Int
  disciplinaId  Int
  professorId   Int?
  instituicaoId Int
  dataInicio    DateTime?
  dataFim       DateTime?
  status        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  turma       Turma       @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina  Disciplina  @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  professor   Professor?  @relation(fields: [professorId], references: [id])
  instituicao Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@unique([turmaId, disciplinaId])
  @@index([turmaId])
  @@index([disciplinaId])
  @@index([professorId])
  @@index([instituicaoId])
}

model Matricula {
  id                     Int                    @id @default(autoincrement())
  alunoId                Int
  createdAt              DateTime               @default(now())
  instituicaoId          Int
  poloId                 Int?
  status                 StatusMatricula        @default(ATIVA)
  updatedAt              DateTime               @updatedAt
  cursoId                Int?
  semestre               Int?
  dataPrimeiroVencimento DateTime?
  quantidadeParcelas     Int?
  valorMatricula         Decimal?               @db.Decimal(10, 2)
  valorMensalidade       Decimal?               @db.Decimal(10, 2)
  primeiroVencimento     DateTime?
  quantidadeMensalidades Int?
  contratos              Contrato[]
  documentos             DocumentoAluno[]
  documentosGerados      DocumentoGerado[]
  itens                  ItemMatricula[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  cursoSemestreId        Int?
  periodoMatriculaId     Int?
  periodoLetivo          String?
  realizadaPeloAluno     Boolean                @default(false)
  confirmadaEm           DateTime?
  cursoSemestre          CursoSemestre?         @relation(fields: [cursoSemestreId], references: [id])
  periodoMatricula       PeriodoMatricula?      @relation(fields: [periodoMatriculaId], references: [id])
  aluno                  Aluno                  @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  curso                  Curso?                 @relation(fields: [cursoId], references: [id])
  instituicao            Instituicao            @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  polo                   Polo?                  @relation(fields: [poloId], references: [id])

  @@index([instituicaoId])
  @@index([alunoId])
  @@index([cursoId])
  @@index([cursoSemestreId])
  @@index([periodoMatriculaId])
  @@index([periodoLetivo])
  @@index([poloId])
}

model ItemMatricula {
  id            Int                 @id @default(autoincrement())
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  instituicaoId Int
  matriculaId   Int
  turmaId       Int
  disciplinaId  Int
  tipoItem      TipoItemMatricula   @default(GRADE_PRINCIPAL)
  status        StatusItemMatricula @default(A_CURSAR)

  instituicao Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  matricula   Matricula   @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  turma       Turma       @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  disciplina  Disciplina  @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  @@unique([matriculaId, turmaId, disciplinaId])
  @@index([instituicaoId])
  @@index([matriculaId])
  @@index([turmaId])
  @@index([disciplinaId])
  @@index([status])
  @@index([tipoItem])
}

model Modulo {
  id            Int         @id @default(autoincrement())
  nome          String
  ordem         Int
  createdAt     DateTime    @default(now())
  instituicaoId Int
  turmaId       Int
  updatedAt     DateTime    @updatedAt
  aulas         Aula[]
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  turma         Turma       @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([turmaId, ordem])
  @@index([instituicaoId])
  @@index([turmaId])
}

model Aula {
  id            Int             @id @default(autoincrement())
  titulo        String
  moduloId      Int?
  createdAt     DateTime        @default(now())
  descricao     String?
  duracaoMin    Int?
  instituicaoId Int
  ordem         Int
  publicada     Boolean         @default(true)
  turmaId       Int
  updatedAt     DateTime        @updatedAt
  videoUrl      String?
  instituicao   Instituicao     @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  modulo        Modulo?         @relation(fields: [moduloId], references: [id])
  turma         Turma           @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  materiais     MaterialAula[]
  presencas     PresencaAula[]
  progresso     ProgressoAula[]

  @@unique([turmaId, ordem])
  @@index([instituicaoId])
  @@index([turmaId])
  @@index([moduloId])
}

model MaterialAula {
  id            Int          @id @default(autoincrement())
  tipo          MaterialTipo
  titulo        String
  url           String?
  arquivoNome   String?
  mimeType      String?
  tamanho       Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  instituicaoId Int
  aulaId        Int
  aula          Aula         @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  instituicao   Instituicao  @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@index([instituicaoId])
  @@index([aulaId])
}

model ProgressoAula {
  id                     Int         @id @default(autoincrement())
  concluida              Boolean     @default(false)
  concluidaEm            DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  instituicaoId          Int
  alunoId                Int
  aulaId                 Int
  tempoAssistidoSegundos Int         @default(0)
  tempoMinimoSegundos    Int         @default(0)
  aluno                  Aluno       @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  aula                   Aula        @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  instituicao            Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@unique([alunoId, aulaId])
  @@index([instituicaoId])
  @@index([alunoId])
  @@index([aulaId])
}

model Atividade {
  id            Int                @id @default(autoincrement())
  titulo        String
  descricao     String?
  prazo         DateTime?
  notaMaxima    Float              @default(10)
  status        StatusAtividade    @default(RASCUNHO)
  publicadaAt   DateTime?
  encerradaAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  instituicaoId Int
  turmaId       Int
  instituicao   Instituicao        @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  turma         Turma              @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  anexos        AtividadeAnexo[]
  entregas      EntregaAtividade[]
  notas         Nota[]

  @@index([instituicaoId])
  @@index([turmaId])
}

model AtividadeAnexo {
  id            Int         @id @default(autoincrement())
  titulo        String
  url           String
  arquivoNome   String?
  mimeType      String?
  tamanho       Int?
  createdAt     DateTime    @default(now())
  instituicaoId Int
  atividadeId   Int
  atividade     Atividade   @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@index([instituicaoId])
  @@index([atividadeId])
}

model EntregaAtividade {
  id            Int         @id @default(autoincrement())
  texto         String?
  link          String?
  arquivoUrl    String?
  nota          Float?
  feedback      String?
  entregueEm    DateTime    @default(now())
  corrigidaEm   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  instituicaoId Int
  atividadeId   Int
  alunoId       Int
  aluno         Aluno       @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  atividade     Atividade   @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  instituicao   Instituicao @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)

  @@unique([atividadeId, alunoId])
  @@index([instituicaoId])
  @@index([atividadeId])
  @@index([alunoId])
}

model Prova {
  id            Int              @id @default(autoincrement())
  titulo        String
  notaMaxima    Float            @default(10)
  ativa         Boolean          @default(true)
  createdAt     DateTime         @default(now())
  descricao     String?
  disponivelEm  DateTime?
  encerradaAt   DateTime?
  expiraEm      DateTime?
  instituicaoId Int
  publicadaAt   DateTime?
  status        StatusProva      @default(RASCUNHO)
  tempoMin      Int?
  tentativasMax Int              @default(1)
  turmaId       Int
  updatedAt     DateTime         @updatedAt
  notas         Nota[]
  instituicao   Instituicao      @relation(fields: [instituicaoId], references: [id], onDelete: Cascade)
  turma         Turma            @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  questoes      Questao[]
  tentativas    TentativaProva[]

  @@index([instituicaoId])
  @@index([turmaId])
  @@index([status])
}

model Questao {
